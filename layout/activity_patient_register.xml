<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:padding="16dp"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/textViewTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/PatientRegister_Title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center"
            android:paddingBottom="24dp" />

        <!-- Κάρτα Εγγραφής -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:orientation="vertical"
            android:padding="16dp"
            android:elevation="4dp"
            android:layout_marginBottom="24dp"
            android:layout_gravity="center">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/PatientRegister_FirstName"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/editTextFirstName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:hint="@string/PatientRegister_FirstName"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/PatientRegister_LastName"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/editTextLastName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:hint="@string/PatientRegister_LastName"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/PatientRegister_BirthDate"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/editTextBirthDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:hint="@string/PatientRegister_BirthDate"
                android:focusable="false"
                android:clickable="true"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/PatientRegister_AMKA"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/editTextAMKA"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:hint="@string/PatientRegister_AMKA"
                android:inputType="number"
                android:maxLength="11"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/PatientRegister_AFM"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/editTextAFM"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:hint="@string/PatientRegister_AFM"
                android:inputType="number"
                android:maxLength="9"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/select_gender"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerGender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:spinnerMode="dropdown" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/PatientRegister_Address"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/editTextAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:hint="@string/PatientRegister_Address"
                android:textSize="16sp"
                android:textLocale="el"
                android:inputType="text|textCapSentences"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/PatientRegister_PhoneNumber"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/editTextPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:hint="@string/PatientRegister_PhoneNumber"
                android:inputType="phone"
                android:maxLength="10"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/PatientRegister_Email"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/editTextEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:hint="@string/PatientRegister_Email"
                android:inputType="textEmailAddress"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/PatientRegister_Password"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <EditText
                    android:id="@+id/editTextPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_edittext"
                    android:padding="12dp"
                    android:hint="@string/PatientRegister_Password"
                    android:inputType="textPassword"
                    android:maxLength="20"
                    android:textSize="16sp" />

                <ImageView
                    android:id="@+id/imgTogglePassword"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/visibility_off_24px"
                    android:contentDescription="@string/PatientRegister_EyeIconVisibility"
                    android:clickable="true"
                    android:focusable="true"/>
            </FrameLayout>

            <!-- Δείκτης Ισχύος Κωδικού -->
            <TextView
                android:id="@+id/textPasswordStrength"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:paddingTop="4dp"
                android:textColor="#888888"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/PatientRegister_ConfirmPassword"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

            <EditText
                android:id="@+id/editTextConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:hint="@string/PatientRegister_ConfirmPassword"
                android:inputType="textPassword"
                android:maxLength="20"
                android:textSize="16sp" />

                <ImageView
                    android:id="@+id/imgToggleConfirmPassword"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/visibility_off_24px"
                    android:contentDescription="@string/PatientRegister_EyeIconVisibility"
                    android:clickable="true"
                    android:focusable="true"/>
            </FrameLayout>

            <Button
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/gradient_button"
                android:textColor="#FFFFFF"
                android:elevation="3dp"
                android:text="@string/PatientRegister_Registerbtn" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>