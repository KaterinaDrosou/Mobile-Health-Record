<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:padding="16dp"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/textViewTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/DoctorRegister_Title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center"
            android:paddingBottom="24dp" />

        <!-- Κάρτα Εγγραφής Γιατρού -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/white"
            android:orientation="vertical"
            android:padding="16dp"
            android:elevation="4dp"
            android:layout_marginBottom="24dp"
            android:layout_gravity="center"
            android:clipToOutline="true">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/DoctorRegister_Name"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/editTextFullName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:hint="@string/DoctorRegister_Name"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/DoctorRegister_Address"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/editTextAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:hint="@string/DoctorRegister_Address"
                android:textSize="16sp"
                android:textLocale="el"
                android:inputType="text|textCapSentences" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/DoctorRegister_PhoneNumber"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/editTextPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:hint="@string/DoctorRegister_PhoneNumber"
                android:inputType="phone"
                android:maxLength="10"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/DoctorRegister_WeeklySchedule"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="16dp"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:id="@+id/layoutWeeklySchedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:divider="?android:attr/dividerHorizontal"
                android:showDividers="middle">

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="4dp">

                    <CheckBox
                        android:id="@+id/checkMonday"
                        android:text="@string/DoctorRegister_Monday"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <EditText
                        android:id="@+id/startMonday"
                        android:hint="@string/DoctorRegister_Start"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="time"
                        android:maxLength="5"
                        android:focusable="true"
                        android:clickable="true"
                        android:background="@drawable/rounded_edittext"
                        android:padding="8dp" />

                    <EditText
                        android:id="@+id/endMonday"
                        android:hint="@string/DoctorRegister_End"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="time"
                        android:maxLength="5"
                        android:focusable="true"
                        android:clickable="true"
                        android:background="@drawable/rounded_edittext"
                        android:padding="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="4dp">

                    <CheckBox
                        android:id="@+id/checkTuesday"
                        android:text="@string/DoctorRegister_Tuesday"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <EditText
                        android:id="@+id/startTuesday"
                        android:hint="@string/DoctorRegister_Start"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="time"
                        android:maxLength="5"
                        android:focusable="true"
                        android:clickable="true"
                        android:background="@drawable/rounded_edittext"
                        android:padding="8dp" />

                    <EditText
                        android:id="@+id/endTuesday"
                        android:hint="@string/DoctorRegister_End"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="time"
                        android:maxLength="5"
                        android:focusable="true"
                        android:clickable="true"
                        android:background="@drawable/rounded_edittext"
                        android:padding="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="4dp">

                    <CheckBox
                        android:id="@+id/checkWednesday"
                        android:text="@string/DoctorRegister_Wednesday"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <EditText
                        android:id="@+id/startWednesday"
                        android:hint="@string/DoctorRegister_Start"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="time"
                        android:maxLength="5"
                        android:focusable="true"
                        android:clickable="true"
                        android:background="@drawable/rounded_edittext"
                        android:padding="8dp" />

                    <EditText
                        android:id="@+id/endWednesday"
                        android:hint="@string/DoctorRegister_End"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="time"
                        android:maxLength="5"
                        android:focusable="true"
                        android:clickable="true"
                        android:background="@drawable/rounded_edittext"
                        android:padding="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="4dp">

                    <CheckBox
                        android:id="@+id/checkThursday"
                        android:text="@string/DoctorRegister_Thursday"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <EditText
                        android:id="@+id/startThursday"
                        android:hint="@string/DoctorRegister_Start"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="time"
                        android:maxLength="5"
                        android:focusable="true"
                        android:clickable="true"
                        android:background="@drawable/rounded_edittext"
                        android:padding="8dp" />

                    <EditText
                        android:id="@+id/endThursday"
                        android:hint="@string/DoctorRegister_End"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="time"
                        android:maxLength="5"
                        android:focusable="true"
                        android:clickable="true"
                        android:background="@drawable/rounded_edittext"
                        android:padding="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="4dp">

                    <CheckBox
                        android:id="@+id/checkFriday"
                        android:text="@string/DoctorRegister_Friday"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <EditText
                        android:id="@+id/startFriday"
                        android:hint="@string/DoctorRegister_Start"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="time"
                        android:maxLength="5"
                        android:focusable="true"
                        android:clickable="true"
                        android:background="@drawable/rounded_edittext"
                        android:padding="8dp" />

                    <EditText
                        android:id="@+id/endFriday"
                        android:hint="@string/DoctorRegister_End"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="time"
                        android:maxLength="5"
                        android:focusable="true"
                        android:clickable="true"
                        android:background="@drawable/rounded_edittext"
                        android:padding="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="4dp">

                    <CheckBox
                        android:id="@+id/checkSaturday"
                        android:text="@string/DoctorRegister_Saturday"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <EditText
                        android:id="@+id/startSaturday"
                        android:hint="@string/DoctorRegister_Start"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="time"
                        android:maxLength="5"
                        android:focusable="true"
                        android:clickable="true"
                        android:background="@drawable/rounded_edittext"
                        android:padding="8dp" />

                    <EditText
                        android:id="@+id/endSaturday"
                        android:hint="@string/DoctorRegister_End"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="time"
                        android:maxLength="5"
                        android:focusable="true"
                        android:clickable="true"
                        android:background="@drawable/rounded_edittext"
                        android:padding="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="4dp">

                    <CheckBox
                        android:id="@+id/checkSunday"
                        android:text="@string/DoctorRegister_Sunday"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <EditText
                        android:id="@+id/startSunday"
                        android:hint="@string/DoctorRegister_Start"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="time"
                        android:maxLength="5"
                        android:focusable="true"
                        android:clickable="true"
                        android:background="@drawable/rounded_edittext"
                        android:padding="8dp" />

                    <EditText
                        android:id="@+id/endSunday"
                        android:hint="@string/DoctorRegister_End"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="time"
                        android:maxLength="5"
                        android:focusable="true"
                        android:clickable="true"
                        android:background="@drawable/rounded_edittext"
                        android:padding="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/DoctorRegister_Specialty"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <!-- Spinner Ειδικότητα -->
            <Spinner
                android:id="@+id/spinnerSpecialty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:spinnerMode="dropdown" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/DoctorRegister_Email"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/editTextEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/rounded_edittext"
                android:padding="12dp"
                android:hint="@string/DoctorRegister_Email"
                android:inputType="textEmailAddress"
                android:textSize="16sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/DoctorRegister_Password"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <EditText
                    android:id="@+id/editTextPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_edittext"
                    android:padding="12dp"
                    android:hint="@string/DoctorRegister_Password"
                    android:inputType="textPassword"
                    android:maxLength="20"
                    android:textSize="16sp" />

                <ImageView
                    android:id="@+id/imgTogglePassword"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/visibility_off_24px"
                    android:contentDescription="@string/DoctorRegister_EyeIconVisibility"
                    android:clickable="true"
                    android:focusable="true"/>
            </FrameLayout>

            <!-- Δείκτης Ισχύος Κωδικού -->
            <TextView
                android:id="@+id/textPasswordStrength"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:paddingTop="4dp"
                android:textColor="#888888"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/DoctorRegister_ConfirmPassword"
                android:textStyle="bold"
                android:textColor="#555555"
                android:paddingTop="12dp"
                android:paddingBottom="4dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <EditText
                    android:id="@+id/editTextConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_edittext"
                    android:padding="12dp"
                    android:hint="@string/DoctorRegister_ConfirmPassword"
                    android:inputType="textPassword"
                    android:maxLength="20"
                    android:textSize="16sp" />

                <ImageView
                    android:id="@+id/imgToggleConfirmPassword"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="12dp"
                    android:src="@drawable/visibility_off_24px"
                    android:contentDescription="@string/DoctorRegister_EyeIconVisibility"
                    android:clickable="true"
                    android:focusable="true"/>
            </FrameLayout>

            <Button
                android:id="@+id/btnRegister"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/gradient_button"
                android:textColor="#FFFFFF"
                android:elevation="3dp"
                android:text="@string/DoctorRegister_Registerbtn" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>